    <script>
        /* --- Chart.js 實體與配置 --- */
        let pieChartInstance = null;
        let scatterChartInstance = null;
        const CHART_COLORS = { A: '#10b981', B: '#f59e0b', C: '#e11d48', D: '#64748b' };

        function initCharts() {
            Chart.defaults.font.family = '"PMingLiU", "新細明體", sans-serif';
            
            const ctxPie = document.getElementById('typePieChart').getContext('2d');
            pieChartInstance = new Chart(ctxPie, {
                type: 'doughnut',
                data: {
                    labels: ['Type C (幻覺)', 'Type B (錯置)', 'Type D (拒答)', 'Type A (正確)'],
                    datasets: [{
                        data: [0, 0, 0, 1],
                        backgroundColor: [CHART_COLORS.C, CHART_COLORS.B, CHART_COLORS.D, CHART_COLORS.A],
                        borderWidth: 0, hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false, cutout: '75%', animation: { duration: 400 },
                    plugins: { legend: { display: false }, tooltip: { callbacks: { label: (ctx) => `${ctx.label || ''}: ${ctx.parsed} 題` } } }
                }
            });

            const ctxScatter = document.getElementById('scatterChart').getContext('2d');
            scatterChartInstance = new Chart(ctxScatter, {
                type: 'scatter',
                data: {
                    datasets: [
                        { label: 'Type C (幻覺)', data: [], backgroundColor: CHART_COLORS.C, pointRadius: 5, pointHoverRadius: 8 },
                        { label: 'Type B (錯置)', data: [], backgroundColor: CHART_COLORS.B, pointRadius: 4, pointHoverRadius: 7 },
                        { label: 'Type A (正確)', data: [], backgroundColor: CHART_COLORS.A, pointRadius: 3, pointHoverRadius: 6 },
                        { label: 'Type D (拒答)', data: [], backgroundColor: CHART_COLORS.D, pointRadius: 4, pointHoverRadius: 7 }
                    ]
                },
                options: {
                    responsive: true, maintainAspectRatio: false, animation: { duration: 400 },
                    plugins: {
                        legend: { display: true, labels: { color: '#94a3b8', boxWidth: 10, font: { size: 10 } } },
                        tooltip: { backgroundColor: 'rgba(15, 23, 42, 0.9)', titleFont: { size: 13 }, bodyFont: { size: 12 }, padding: 10,
                            callbacks: { label: (ctx) => [`📌 ${ctx.raw.title}`, `模型: ${ctx.raw.model}`, `延遲: ${ctx.raw.x} ms`, `風險: ${ctx.raw.y} HRS`] }
                        }
                    },
                    scales: {
                        x: { type: 'linear', position: 'bottom', grid: { color: 'rgba(51, 65, 85, 0.5)', drawBorder: false }, ticks: { color: '#94a3b8', font: { family: 'Lato' } } },
                        y: { beginAtZero: true, max: 1.0, grid: { color: 'rgba(51, 65, 85, 0.5)', drawBorder: false }, ticks: { color: '#94a3b8', font: { family: 'Lato' } } }
                    }
                }
            });
        }

        window.addEventListener('DOMContentLoaded', () => {
            initCharts();
            setTimeout(() => { runSimulation(false); }, 500);
        });

        /* --- 狀態控制與超參數 (Hyperparameters) --- */
        let isRunning = false;
        const mechanisms = { m1: true, m2: true, m3: true, m4: true, m5: true };
        
        const MODEL_MAP = {
            'gpt-4o': 'GPT-4o (基準線)',
            'gpt-4o-mini': 'GPT-4o mini (輕量版)',
            'gpt-5-nano': 'GPT-5 Nano (超輕量/邊緣運算)',
            'gpt-5.2': 'GPT-5.2 (旗艦版)',
            'gpt-o3-baseline': 'GPT-o3 (Baseline) (強推理-基準)',
            'gpt-o3-cot': 'GPT-o3 (CoT) (強推理-思維鍊)',
            'gemini-3.0-flash': 'Gemini 3.0 Flash (輕量版)',
            'gemini-3.0-pro': 'Gemini 3.0 Pro (General) (通用版)',
            'gemini-3.0-flagship': 'Gemini 3.0 Flagship (旗艦版)',
            'gemini-3.0-intuition': 'Gemini 3.0 Intuition (直覺快思)',
            'gemini-3.0-safe': 'Gemini 3.0 Safe (高安全版)',
            'gemini-3.0-thinking': 'Gemini 3.0 Thinking (CoT) (思維鍊版)'
        };
        
        let modelStates = Object.keys(MODEL_MAP).reduce((acc, key) => { acc[key] = true; return acc; }, {});
        
        const hyperParams = { temp: 0.7, kValue: 3, cot: 1 };

        function updateHyperparam(key, value) {
            hyperParams[key] = parseFloat(value);
            let displayVal = value;
            if (key === 'kValue') displayVal += ' 篇';
            if (key === 'cot') displayVal += ' 階';
            
            document.getElementById(`val-${key}`).innerText = displayVal;
            
            document.getElementById('hyper-status').classList.replace('text-slate-400', 'text-indigo-600');
            document.getElementById('hyper-status').classList.replace('bg-slate-100', 'bg-indigo-100');
            setTimeout(() => {
                document.getElementById('hyper-status').classList.replace('text-indigo-600', 'text-slate-400');
                document.getElementById('hyper-status').classList.replace('bg-indigo-100', 'bg-slate-100');
            }, 500);
        }

        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            if(sidebar.classList.contains('-translate-x-full')) sidebar.classList.remove('-translate-x-full');
            else sidebar.classList.add('-translate-x-full');
        }

        function toggleMechanism(id) {
            mechanisms[id] = !mechanisms[id];
            updateToggleUI(id, mechanisms[id]);
            
            if (id === 'm5') {
                const cotContainer = document.getElementById('cot-slider-container');
                const cotSlider = document.getElementById('slider-cot');
                const cotVal = document.getElementById('val-cot');
                if (mechanisms.m5) {
                    cotContainer.classList.remove('opacity-40', 'pointer-events-none', 'grayscale');
                    cotSlider.disabled = false;
                    cotVal.classList.replace('bg-slate-100', 'bg-amber-50');
                    cotVal.classList.replace('text-slate-400', 'text-amber-600');
                    cotVal.innerText = hyperParams.cot + ' 階';
                } else {
                    cotContainer.classList.add('opacity-40', 'pointer-events-none', 'grayscale');
                    cotSlider.disabled = true;
                    cotVal.classList.replace('bg-amber-50', 'bg-slate-100');
                    cotVal.classList.replace('text-amber-600', 'text-slate-400');
                    cotVal.innerText = 'M5已關閉';
                }
            }
        }

        function toggleModel(id) {
            modelStates[id] = !modelStates[id];
            updateSmallToggleUI(`model-${id}`, modelStates[id], false);
            checkMasterState();
        }

        function toggleMaster(family) {
            const keys = Object.keys(MODEL_MAP).filter(k => k.startsWith(family === 'openai' ? 'gpt' : 'gemini'));
            const allOn = keys.every(k => modelStates[k]);
            const targetState = !allOn;
            
            keys.forEach(k => {
                modelStates[k] = targetState;
                updateSmallToggleUI(`model-${k}`, targetState, false);
            });
            updateSmallToggleUI(`master-${family}`, targetState, true);
        }

        function checkMasterState() {
            ['openai', 'gemini'].forEach(family => {
                const keys = Object.keys(MODEL_MAP).filter(k => k.startsWith(family === 'openai' ? 'gpt' : 'gemini'));
                const allOn = keys.every(k => modelStates[k]);
                updateSmallToggleUI(`master-${family}`, allOn, true);
            });
        }

        function updateSmallToggleUI(id, isEnabled, isMaster) {
            const el = document.getElementById(id);
            if(!el) return;
            const knob = el.firstElementChild;
            const translateOn = isMaster ? 'translate-x-4' : 'translate-x-3';
            
            if (isEnabled) {
                el.classList.replace('bg-slate-300', 'bg-indigo-600');
                knob.classList.add(translateOn);
            } else {
                el.classList.replace('bg-indigo-600', 'bg-slate-300');
                knob.classList.remove(translateOn);
            }
        }

        function updateToggleUI(id, isEnabled) {
            const el = document.getElementById(id);
            if(!el) return;
            const knob = el.firstElementChild;
            if (isEnabled) {
                el.classList.replace('bg-slate-300', 'bg-indigo-600');
                knob.classList.add('translate-x-4');
            } else {
                el.classList.replace('bg-indigo-600', 'bg-slate-300');
                knob.classList.remove('translate-x-4');
            }
        }

        /* --- 彈出視窗 --- */
        const modal = document.getElementById('detail-modal');
        const modalContent = document.getElementById('modal-content');
        function openModal(dataStr) {
            const data = JSON.parse(decodeURIComponent(dataStr));
            document.getElementById('modal-title').innerText = data.title;
            document.getElementById('modal-model').innerText = data.model;
            document.getElementById('modal-time').innerText = data.timestamp;
            document.getElementById('modal-lat').innerText = data.latency + ' ms';
            document.getElementById('modal-fad').innerText = data.fad;
            document.getElementById('modal-hrs').innerText = data.hrs;
            
            const badge = document.getElementById('modal-badge');
            badge.innerText = data.type.replace('_', ' ');
            badge.className = 'px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider ';
            let desc = "";
            if(data.type === 'Type_A') { badge.classList.add('bg-emerald-100', 'text-emerald-700'); desc = "「事實密度高，未偵測到過度斷言語氣，判定為完全正確。」"; }
            else if(data.type === 'Type_B') { badge.classList.add('bg-amber-100', 'text-amber-700'); desc = "「流暢度極高，但發現事實偏移，屬於隱蔽性極強的知識錯置。」"; }
            else if(data.type === 'Type_C') { badge.classList.add('bg-rose-100', 'text-rose-700'); desc = "「生成延遲異常且邏輯矛盾，為高後果核心幻覺。」"; }
            else { badge.classList.add('bg-slate-200', 'text-slate-700'); desc = "「觸發安全機制，模型採取保守策略拒絕回答。」"; }
            document.getElementById('modal-desc').innerText = desc;
            modal.classList.remove('hidden');
            setTimeout(() => { modal.classList.remove('opacity-0'); modalContent.classList.remove('scale-95'); }, 10);
        }
        function closeModal() {
            modal.classList.add('opacity-0'); modalContent.classList.add('scale-95');
            setTimeout(() => modal.classList.add('hidden'), 200);
        }
        document.addEventListener('keydown', (e) => { if (e.key === "Escape" && !modal.classList.contains('hidden')) closeModal(); });

        /* --- 動態高階數學數據引擎 (結合超參數) --- */
        const MODEL_PROFILES = {
            'GPT-4o (基準線)': { tC: 0.05, tB: 0.08, tD: 0.05, lat: 5500, fad: 0.88 },
            'GPT-4o mini (輕量版)': { tC: 0.15, tB: 0.12, tD: 0.07, lat: 2500, fad: 0.76 },
            'GPT-5 Nano (超輕量/邊緣運算)': { tC: 0.20, tB: 0.18, tD: 0.08, lat: 1200, fad: 0.68 },
            'GPT-5.2 (旗艦版)': { tC: 0.01, tB: 0.03, tD: 0.04, lat: 12500, fad: 0.96 },
            'GPT-o3 (Baseline) (強推理-基準)': { tC: 0.03, tB: 0.05, tD: 0.06, lat: 8500, fad: 0.90 },
            'GPT-o3 (CoT) (強推理-思維鍊)': { tC: 0.005, tB: 0.01, tD: 0.08, lat: 22000, fad: 0.98 },
            'Gemini 3.0 Flash (輕量版)': { tC: 0.12, tB: 0.10, tD: 0.05, lat: 2200, fad: 0.82 },
            'Gemini 3.0 Pro (General) (通用版)': { tC: 0.04, tB: 0.06, tD: 0.04, lat: 4500, fad: 0.90 },
            'Gemini 3.0 Flagship (旗艦版)': { tC: 0.01, tB: 0.02, tD: 0.03, lat: 11000, fad: 0.97 },
            'Gemini 3.0 Intuition (直覺快思)': { tC: 0.08, tB: 0.15, tD: 0.02, lat: 1500, fad: 0.78 },
            'Gemini 3.0 Safe (高安全版)': { tC: 0.01, tB: 0.02, tD: 0.25, lat: 5000, fad: 0.85 },
            'Gemini 3.0 Thinking (CoT) (思維鍊版)': { tC: 0.005, tB: 0.01, tD: 0.06, lat: 18000, fad: 0.96 }
        };

        function runSimulation(isInstant = false) {
            if(isRunning && !isInstant) return;
            const selectedModels = Object.keys(modelStates)
                .filter(k => modelStates[k])
                .map(k => MODEL_MAP[k]);

            if(selectedModels.length === 0) { alert("請至少開啟一種模型進行測試"); return; }

            isRunning = true;
            const overlay = document.getElementById('loading-overlay');
            const progressText = document.getElementById('progress-text');
            if(!isInstant) {
                overlay.classList.remove('hidden'); overlay.classList.add('flex');
            }

            // 1. 機制開關基礎影響
            const activeMechs = Object.values(mechanisms).filter(v=>v).length;
            const baseReduction = activeMechs * 0.12; 

            // 2. 超參數數學轉換矩陣 (Hyperparameter Math Matrix)
            const tempFactorC = Math.pow((hyperParams.temp / 0.7), 1.5); 
            const tempFactorD = Math.max(0.1, 1 - (hyperParams.temp - 0.7)); 

            const kFactorB = Math.max(0.2, 1 - (hyperParams.kValue * 0.08)); 
            const kLatPenalty = hyperParams.kValue * 150; 
            const kFadBoost = hyperParams.kValue * 0.015;

            // 只有在 M5 開啟時，才套用 CoT 數學轉換
            let cotFactorC = 1;
            let cotLatMultiplier = 1;
            if (mechanisms.m5) {
                cotFactorC = Math.max(0, 1 - ((hyperParams.cot - 1) * 0.3)); 
                cotLatMultiplier = 1 + ((hyperParams.cot - 1) * 0.6); 
            }

            let results = [], typeCounts = { A: 0, B: 0, C: 0, D: 0 }, totalItems = 225;

            for(let i=0; i<totalItems; i++) {
                const model = selectedModels[Math.floor(Math.random() * selectedModels.length)];
                const prof = MODEL_PROFILES[model];
                
                const effTypeC = Math.max(0, prof.tC * (1 - baseReduction) * tempFactorC * cotFactorC);
                const effTypeB = Math.max(0, prof.tB * tempFactorC * kFactorB);
                const effTypeD = Math.max(0, prof.tD * tempFactorD);
                
                const rand = Math.random();
                let type = 'Type_A';
                if(rand < effTypeC) { type = 'Type_C'; typeCounts.C++; }
                else if(rand < effTypeC + effTypeB) { type = 'Type_B'; typeCounts.B++; }
                else if(rand < effTypeC + effTypeB + effTypeD) { type = 'Type_D'; typeCounts.D++; }
                else { typeCounts.A++; }

                const typeLatMult = type === 'Type_C' ? 1.3 : (type === 'Type_B' ? 1.1 : 1.0);
                const finalLatency = Math.floor((prof.lat * (0.8 + Math.random()*0.4) * typeLatMult * cotLatMultiplier) + kLatPenalty);
                const finalFad = Math.min(0.99, prof.fad * (0.9 + Math.random()*0.1) + kFadBoost).toFixed(2);
                
                const hrsBase = type === 'Type_C' ? 0.85 : (type === 'Type_B' ? 0.45 : 0.05);

                results.push({
                    id: i, title: `華語測試題 #${String(i+1).padStart(3, '0')}`, model: model, type: type,
                    latency: finalLatency, fad: finalFad, hrs: hrsBase.toFixed(3),
                    timestamp: new Date().toLocaleTimeString('en-US', { hour12: false })
                });
            }

            setTimeout(() => {
                updateUI(results, typeCounts, totalItems);
                if(!isInstant) {
                    overlay.classList.add('hidden'); overlay.classList.remove('flex');
                    progressText.innerText = "分析完成";
                    progressText.classList.replace('bg-slate-200', 'bg-indigo-100');
                    progressText.classList.replace('text-slate-600', 'text-indigo-700');
                }
                isRunning = false;
                window.generatedData = true; // 新增：觸發完畢後確保滑桿連動可以生效
            }, isInstant ? 0 : 800);
        }

        function updateUI(data, counts, total) {
            const avgHrs = data.reduce((sum, r) => sum + parseFloat(r.hrs), 0) / total;
            const avgFad = data.reduce((sum, r) => sum + parseFloat(r.fad), 0) / total;
            const avgLat = data.reduce((sum, r) => sum + r.latency, 0) / total;
            const intervention = ((counts.B + counts.C + counts.D) / total * 100).toFixed(1);
            
            const activeMechs = Object.values(mechanisms).filter(v=>v).length;
            const simulatedKappa = (0.83 + (activeMechs * 0.01) + (Math.random() * 0.02)).toFixed(2);

            document.getElementById('kpi-hrs').innerText = avgHrs.toFixed(3);
            document.getElementById('kpi-fad').innerText = avgFad.toFixed(2);
            document.getElementById('kpi-latency').innerText = Math.floor(avgLat).toLocaleString();
            document.getElementById('kpi-intervention').innerText = `${intervention}%`;
            document.getElementById('kpi-kappa').innerText = simulatedKappa;

            const tbody = document.getElementById('table-body');
            tbody.innerHTML = '';
            data.slice(0, 50).forEach(row => {
                const tr = document.createElement('tr');
                tr.className = 'hover:bg-slate-50 transition-colors cursor-pointer group';
                tr.onclick = () => openModal(encodeURIComponent(JSON.stringify(row)));
                let badgeClass = row.type === 'Type_A' ? 'bg-emerald-100 text-emerald-700' : row.type === 'Type_B' ? 'bg-amber-100 text-amber-700' : row.type === 'Type_C' ? 'bg-rose-100 text-rose-700' : 'bg-slate-200 text-slate-700';
                tr.innerHTML = `
                    <td class="px-6 py-4"><p class="font-bold text-slate-800 group-hover:text-indigo-600 transition-colors">${row.title}</p><p class="text-[10px] text-slate-400 font-mono mt-0.5">${row.model}</p></td>
                    <td class="px-4 py-4"><span class="px-2.5 py-1 rounded-md text-[10px] font-black uppercase tracking-wider ${badgeClass}">${row.type.replace('_', ' ')}</span></td>
                    <td class="px-4 py-4 text-right font-mono text-slate-500 text-xs mobile-hide">${row.latency}</td>
                    <td class="px-4 py-4 text-right font-mono font-bold text-sm ${row.hrs > 0.5 ? 'text-rose-600' : 'text-slate-700'}">${row.hrs}</td>
                `;
                tbody.appendChild(tr);
            });

            document.getElementById('pie-total').innerText = total;
            document.getElementById('leg-c').innerText = ((counts.C / total) * 100).toFixed(1) + '%';
            document.getElementById('leg-b').innerText = ((counts.B / total) * 100).toFixed(1) + '%';
            document.getElementById('leg-d').innerText = ((counts.D / total) * 100).toFixed(1) + '%';
            document.getElementById('leg-a').innerText = ((counts.A / total) * 100).toFixed(1) + '%';
            pieChartInstance.data.datasets[0].data = [counts.C, counts.B, counts.D, counts.A];
            pieChartInstance.update();

            const sData = { C:[], B:[], A:[], D:[] };
            data.slice(0, 100).forEach(r => {
                const pt = { x: r.latency, y: parseFloat(r.hrs), title: r.title, model: r.model };
                if(r.type==='Type_C') sData.C.push(pt); else if(r.type==='Type_B') sData.B.push(pt); else if(r.type==='Type_A') sData.A.push(pt); else sData.D.push(pt);
            });
            scatterChartInstance.data.datasets[0].data = sData.C;
            scatterChartInstance.data.datasets[1].data = sData.B;
            scatterChartInstance.data.datasets[2].data = sData.A;
            scatterChartInstance.data.datasets[3].data = sData.D;
            scatterChartInstance.update();
        }
    </script>
</body>
</html>
